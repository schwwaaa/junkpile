{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "../src",
    "distDir": "../src"
  },
  "package": {
    "productName": "feedback-single-template",
    "version": "0.1.0"
  },
  "tauri": {
    "windows": [
      {
        "label": "main",
        "title": "Feedback \u00b7 Tauri v1 \u00b7 Single Window",
        "url": "index.html",
        "width": 1280,
        "height": 780,
        "resizable": true
      }
    ],
    "bundle": {
      "active": true,
      "identifier": "com.example.feedback-single-v1",
      "icon": [
        "icons/icon.icns",
        "icons/icon.png",
        "icons/icon.ico"
      ],
      "macOS": {
        "entitlements": "entitlements.plist"
      }
    },
    "security": {
      "csp": "default-src 'self'; media-src 'self' blob: mediastream:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  }
}