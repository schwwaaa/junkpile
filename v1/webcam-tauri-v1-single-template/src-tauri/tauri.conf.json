{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeBuildCommand": "", "beforeDevCommand": "",
    "devPath": "../src", "distDir": "../src"
  },
  "package": { "productName": "webcam-single-template", "version": "0.1.0" },
  "tauri": {
    "windows": [{
      "label": "main",
      "title": "Webcam · Tauri v1 · Single Window",
      "url": "index.html",
      "width": 1200, "height": 750,
      "resizable": true, "decorations": true
    }],
    "bundle": {
      "active": true,
      "identifier": "com.example.webcam-single-template",
      "icon": ["icons/icon.icns","icons/icon.png","icons/icon.ico"],
      "macOS": { "entitlements": "entitlements.plist" }
    },
    "security": {
      "csp": "default-src 'self'; media-src 'self' blob: mediastream:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  }
}
