{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "../src",
    "distDir": "../src"
  },
  "package": {
    "productName": "feedback-ws-template",
    "version": "0.1.0"
  },
  "tauri": {
    "windows": [
      {
        "label": "controls",
        "title": "Controls",
        "url": "controls.html",
        "width": 280,
        "height": 800,
        "resizable": true,
        "x": 40,
        "y": 60
      },
      {
        "label": "canvas",
        "title": "Feedback Output",
        "url": "canvas.html",
        "width": 1000,
        "height": 780,
        "resizable": true,
        "x": 360,
        "y": 60
      }
    ],
    "bundle": {
      "active": true,
      "identifier": "com.example.feedback-ws-v1",
      "icon": [
        "icons/icon.icns",
        "icons/icon.png",
        "icons/icon.ico"
      ],
      "macOS": {
        "entitlements": "entitlements.plist"
      }
    },
    "security": {
      "csp": "default-src 'self'; connect-src ws://127.0.0.1:2727 ws://[::1]:2727; media-src 'self' blob: mediastream:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  }
}