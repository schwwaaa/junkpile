{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "webcam-ws-template",
  "version": "0.1.0",
  "identifier": "com.example.webcam-ws-template",
  "build": {
    "beforeBuildCommand": "", "beforeDevCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label":       "controls",
        "title":       "Controls",
        "url":         "controls.html",
        "width":       300,
        "height":      780,
        "resizable":   true,
        "decorations": true,
        "x": 40, "y": 60
      },
      {
        "label":       "canvas",
        "title":       "Webcam Output",
        "url":         "canvas.html",
        "width":       960,
        "height":      720,
        "resizable":   true,
        "decorations": true,
        "x": 380, "y": 60
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ws://127.0.0.1:2727 ws://[::1]:2727; media-src 'self' blob: mediastream:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.icns","icons/icon.png","icons/icon.ico"],
    "macOS": { "entitlements": "entitlements.plist" }
  }
}
