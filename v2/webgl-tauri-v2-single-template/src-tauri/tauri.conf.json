{
  "$schema": "https://schema.tauri.app/config/2",

  "productName": "webgl-single-template",
  "version":     "0.1.0",
  "identifier":  "com.example.webgl-single-template",

  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand":   "",
    "frontendDist":       "../src"
  },

  "app": {
    "windows": [
      {
        "label":       "main",
        "title":       "WebGL · Tauri v2 · Single Window",
        "url":         "index.html",
        "width":       1100,
        "height":      720,
        "resizable":   true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },

  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.icns",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
